# CloudXR device-profile env file for the Isaac Teleop XR -> SO-101 example.
#
# Passed to isaacteleop's CloudXRLauncher as `env_config` (via
# XRControllerConfig.cloudxr_env_file). Format is KEY=value, one per line;
# `#` comments and blank lines are ignored, and values are expanded for
# $VARS / ~ (see isaacteleop/cloudxr/env_config.py::_load_env_file).
#
# These override CloudXR's built-in defaults. Only the keys below are
# user-settable; the runtime-resolved keys (XR_RUNTIME_JSON, XRT_NO_STDIN,
# NV_CXR_RUNTIME_DIR, NV_CXR_OUTPUT_DIR) are reserved and ignored if set here.

# Device/transport profile the CloudXR runtime advertises. The built-in default
# is "auto-webrtc" (WebXR / browser-based headset clients over WebRTC); other
# valid profiles are auto-native, Quest3, and AppleVisionPro. This file
# deliberately overrides that default to "Quest3" — despite the name it works
# for both the Meta Quest 3 and the Pico 4, so this single profile covers the
# headsets this example targets.
NV_DEVICE_PROFILE=Quest3

# Input device discovery: push-device + tensor-data channels. Both default to
# true; pinned here for clarity. Leave on for XR controller teleop.
NV_CXR_ENABLE_PUSH_DEVICES=true
NV_CXR_ENABLE_TENSOR_DATA=true

# Write CloudXR runtime logs to ~/.cloudxr/logs (handy when debugging
# connection issues such as "Failed to get OpenXR system: -35").
NV_CXR_FILE_LOGGING=true
