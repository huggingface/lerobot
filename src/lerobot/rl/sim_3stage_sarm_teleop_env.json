{
    "env": {
        "name": "sim_assembling",
        "task": "AssembleBase-v0",
        "fps": 20,
        "realtime": true,
        "robot": null,
        "teleop": {
            "type": "gamepad",
            "use_gripper": true,
            "use_yaw": true,
            "stage_advance_button": 0,
            "record_gripper_width": true
        },
        "processor": {
            "control_mode": "gamepad",
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": 0.0,
                "record_gripper_width": true
            },
            "reset": {
                "reset_time_s": 0.0,
                "control_time_s": 60.0,
                "terminate_on_success": false
            },
            "stage_names": [
                "approach_box",
                "bring_box",
                "approach_target",
                "place_target_in_the_box",
                "approach_cover",
                "place_cover_on_the_box"
            ],
            "reward_model": {
                "type": "sarm_ext",
                "pretrained_path": "outputs/sim_3stage_sarm_v2_full_v2_paperfull_lowlr/checkpoints/024000/pretrained_model",
                "device": "cuda",
                "task": "Three-stage assembly",
                "head_mode": "sparse",
                "reward_mode": "delta",
                "success_threshold": 0.5,
                "stats_dataset_repo_id": "local/sim_3stage_v2_full_v2_nostale",
                "eval_every_n_steps": 1,
                "verbose": true,
                "verbose_every_n_steps": 2,
                "sync_inference": true,
                "log_jsonl_path": "outputs/teleop_logs/sarm_teleop.jsonl"
            },
            "inverse_kinematics": {
                "end_effector_bounds": {
                    "min": [
                        -0.14,
                        -0.77,
                        0.33
                    ],
                    "max": [
                        0.18,
                        -0.4845,
                        0.38
                    ]
                }
            }
        },
        "render_mode": "all",
        "image_size": [128, 128],
        "action_step_size": 0.01,
        "include_yaw_slot": true,
        "yaw_step_size": 0.1,
        "object_spawn_offset": [
            0.1,
            0.0,
            0.0
        ]
    },
    "device": "cuda",
    "rerun": true,
    "dataset": {
        "repo_id": "local/_teleop_dummy",
        "task": "AssembleBase-v0"
    }
}
