{
  "output_dir": "outputs/sim_3stage_act_eval_K_sync",
  "job_name": "sim_3stage_act_eval_K_sync",
  "resume": false,
  "seed": 1000,
  "offline_dataset_stride": 1,
  "num_workers": 0,
  "batch_size": 1,
  "steps": 1,
  "eval_freq": 0,
  "log_freq": 1,
  "save_checkpoint": false,
  "save_freq": 0,
  "use_policy_training_preset": false,
  "optimizer": null,
  "scheduler": null,
  "wandb": {
    "enable": false
  },
  "dataset": {
    "repo_id": "domrachev03/sim_assemble_sarm_multistage_three_stages_success",
    "use_imagenet_stats": true
  },
  "env": {
    "type": "gym_manipulator",
    "name": "sim_assembling",
    "task": "AssembleBase-v0",
    "fps": 20,
    "realtime": false,
    "render_mode": "all",
    "robot": null,
    "teleop": null,
    "processor": {
      "control_mode": "gamepad",
      "gripper": {
        "use_gripper": true,
        "gripper_penalty": 0.0,
        "record_gripper_width": true
      },
      "reset": {
        "reset_time_s": 0.0,
        "control_time_s": 60.0,
        "terminate_on_success": true
      },
      "stage_names": [
        "approach_box",
        "bring_box",
        "approach_target",
        "place_target_in_the_box",
        "approach_cover",
        "place_cover_on_the_box"
      ],
      "reward_model": {
        "type": "sarm_ext",
        "pretrained_path": "outputs/sarm_shorthor_k_n4g2_sw20/checkpoints/002500/pretrained_model",
        "device": "cuda",
        "task": "Three-stage assembly",
        "head_mode": "sparse",
        "reward_mode": "delta",
        "success_threshold": 0.95,
        "stats_dataset_repo_id": "local/sim_3stage_v2_full_v2_nostale",
        "eval_every_n_steps": 1,
        "sync_inference": true
      },
      "inverse_kinematics": {
        "end_effector_bounds": {
          "min": [
            -0.1708,
            -0.8781,
            0.33
          ],
          "max": [
            0.18,
            -0.4845,
            0.38
          ]
        }
      }
    },
    "action_step_size": 0.01,
    "include_yaw_slot": true,
    "yaw_step_size": 0.1,
    "object_spawn_offset": [
      0.1,
      0.0,
      0.0
    ],
    "features": {
      "observation.images.front": {
        "type": "VISUAL",
        "shape": [
          3,
          224,
          224
        ]
      },
      "observation.images.wrist": {
        "type": "VISUAL",
        "shape": [
          3,
          224,
          224
        ]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [
          7
        ]
      },
      "action": {
        "type": "ACTION",
        "shape": [
          5
        ]
      }
    },
    "features_map": {
      "observation.images.front": "observation.images.front",
      "observation.images.wrist": "observation.images.wrist",
      "observation.state": "observation.state",
      "action": "action"
    }
  },
  "policy": {
    "type": "act",
    "n_obs_steps": 1,
    "chunk_size": 20,
    "n_action_steps": 20,
    "vision_backbone": "resnet18",
    "pretrained_backbone_weights": "ResNet18_Weights.IMAGENET1K_V1",
    "use_vae": true,
    "kl_weight": 10.0,
    "dim_model": 512,
    "n_heads": 8,
    "dim_feedforward": 3200,
    "n_encoder_layers": 4,
    "n_decoder_layers": 1,
    "dropout": 0.1,
    "optimizer_lr": 1e-05,
    "optimizer_lr_backbone": 1e-05,
    "optimizer_weight_decay": 0.0001,
    "device": "cuda",
    "use_amp": true,
    "normalization_mapping": {
      "VISUAL": "MEAN_STD",
      "STATE": "MIN_MAX",
      "ACTION": "MIN_MAX"
    },
    "input_features": {
      "observation.images.front": {
        "type": "VISUAL",
        "shape": [
          3,
          224,
          224
        ]
      },
      "observation.images.wrist": {
        "type": "VISUAL",
        "shape": [
          3,
          224,
          224
        ]
      },
      "observation.state": {
        "type": "STATE",
        "shape": [
          7
        ]
      }
    },
    "output_features": {
      "action": {
        "type": "ACTION",
        "shape": [
          5
        ]
      }
    },
    "repo_id": "local/act_3stage_v3"
  }
}