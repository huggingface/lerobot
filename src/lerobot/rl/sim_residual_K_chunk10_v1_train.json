      "observation.state":        {"type": "STATE",  "shape": [7]},
      "action":                   {"type": "ACTION", "shape": [5]}
    },
    "features_map": {
      "observation.images.front": "observation.images.front",
      "observation.images.wrist": "observation.images.wrist",
      "observation.state": "observation.state",
      "action": "action"
    },
    "image_size": [128, 128]
