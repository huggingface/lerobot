    "policy_kwargs": {"use_tanh_squash": true, "std_min": 0.05, "std_max": [2.0, 2.0, 2.0, 2.0, 0.3], "init_final": 0.01},
    "residual_mode": true,
    "base_policy_path": "outputs/act_v2_full_6stg_bc_chunk10_v11/checkpoints/060000/pretrained_model",
    "base_policy_type": "act",
