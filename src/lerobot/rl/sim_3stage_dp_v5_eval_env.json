{
    "output_dir": "outputs/sim_3stage_dp_v5_eval",
    "job_name": "sim_3stage_dp_v5_eval",
    "resume": false,
    "seed": 1000,
    "offline_dataset_stride": 1,
    "num_workers": 0,
    "batch_size": 1,
    "steps": 1,
    "eval_freq": 0,
    "log_freq": 1,
    "save_checkpoint": false,
    "save_freq": 0,
    "use_policy_training_preset": false,
    "wandb": {"enable": false},
    "dataset": {
        "repo_id": "domrachev03/sim_3stage_v5_train_fs",
        "use_imagenet_stats": true
    },
    "env": {
        "type": "gym_manipulator",
        "name": "sim_assembling",
        "task": "AssembleBase-v0",
        "fps": 20,
        "realtime": false,
        "render_mode": "rgb_array",
        "image_size": [224, 224],
        "robot": null,
        "teleop": null,
        "processor": {
            "control_mode": "gamepad",
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": 0.0,
                "record_gripper_width": true
            },
            "reset": {
                "reset_time_s": 0.0,
                "control_time_s": 30.0,
                "terminate_on_success": false
            },
            "stage_names": [
                "approach_box",
                "bring_box",
                "approach_target",
                "place_target_in_the_box",
                "approach_cover",
                "place_cover_on_the_box"
            ],
            "reward_model": {
                "type": "sarm_ext",
                "pretrained_path": "outputs/sarm_v5_succonly/checkpoints/020000/pretrained_model",
                "device": "cuda",
                "task": "Three-stage assembly",
                "head_mode": "sparse",
                "reward_mode": "dense",
                "success_threshold": 0.95,
                "success_reward": 0.0,
                "stats_dataset_repo_id": "domrachev03/sim_3stage_v5_success_destale_t30",
                "eval_every_n_steps": 1,
                "sync_inference": true,
                "warmup_steps": 20,
                "verbose": true,
                "verbose_every_n_steps": 50
            },
            "inverse_kinematics": {
                "end_effector_bounds": {
                    "min": [-0.14, -0.77, 0.33],
                    "max": [0.18, -0.4845, 0.38]
                }
            }
        },
        "action_step_size": 0.01,
        "include_yaw_slot": true,
        "yaw_step_size": 0.1,
        "object_spawn_offset": [0.1, 0.0, 0.0]
    },
    "policy": {
        "type": "diffusion",
        "n_obs_steps": 2,
        "horizon": 16,
        "n_action_steps": 8,
        "vision_backbone": "resnet18",
        "pretrained_backbone_weights": "ResNet18_Weights.IMAGENET1K_V1",
        "use_group_norm": false,
        "device": "cuda",
        "use_amp": true,
        "normalization_mapping": {
            "VISUAL": "MEAN_STD",
            "STATE": "MIN_MAX",
            "ACTION": "MIN_MAX"
        },
        "input_features": {
            "observation.images.front": {"type": "VISUAL", "shape": [3, 224, 224]},
            "observation.images.wrist": {"type": "VISUAL", "shape": [3, 224, 224]},
            "observation.state": {"type": "STATE", "shape": [7]}
        },
        "output_features": {
            "action": {"type": "ACTION", "shape": [5]}
        },
        "diffusion_step_embed_dim": 128,
        "down_dims": [256, 512, 1024],
        "kernel_size": 5,
        "n_groups": 8,
        "use_film_scale_modulation": true,
        "noise_scheduler_type": "DDIM",
        "num_train_timesteps": 100,
        "num_inference_steps": 10,
        "repo_id": "local/dp_v5_destale_t30"
    }
}
