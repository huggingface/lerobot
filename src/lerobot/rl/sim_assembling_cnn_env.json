                "success_reward": 1.0
            },
            "inverse_kinematics": {
                "end_effector_bounds": {
                    "min": [
                        -0.1708,
                        -0.8781,
                        0.3202
                    ],
                    "max": [
                        0.2538,
                        -0.4845,
                        0.3589
                    ]
                }
            }
        },
        "render_mode": "all",
        "action_step_size": 0.01,
        "include_yaw_slot": true,
        "yaw_step_size": 0.05,
        "object_spawn_offset": [
            0.25,
            0.0,
            0.0
        ]
    },
    "device": "cuda"
}