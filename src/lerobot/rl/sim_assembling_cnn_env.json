{
    "env": {
        "name": "sim_assembling",
        "task": "AssembleBase-v0",
        "fps": 20,
        "realtime": false,
        "robot": null,
        "teleop": {
            "type": "gamepad",
            "use_gripper": true,
            "use_yaw": true
        },
        "processor": {
            "control_mode": "gamepad",
            "gripper": {
                "use_gripper": true,
                "gripper_penalty": 0.0
            },
            "reset": {
                "reset_time_s": 0.0,
                "control_time_s": 20.0,
                "terminate_on_success": true
            },
            "reward_model": {
                "type": "cnn",
                "pretrained_path": "outputs/sim_assembling_cnn_reward/checkpoints/last/pretrained_model",
