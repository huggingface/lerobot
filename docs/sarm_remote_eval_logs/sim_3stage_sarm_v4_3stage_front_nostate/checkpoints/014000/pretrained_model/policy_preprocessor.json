{
  "name": "policy_preprocessor",
  "steps": [
    {
      "registry_name": "to_batch_processor",
      "config": {}
    },
    {
      "registry_name": "rename_observations_processor",
      "config": {
        "rename_map": {}
      }
    },
    {
      "registry_name": "normalizer_processor",
      "config": {
        "eps": 1e-08,
        "features": {
          "observation.images.front": {
            "type": "VISUAL",
            "shape": [
              480,
              640,
              3
            ]
          },
          "observation.state": {
            "type": "STATE",
            "shape": [
              32
            ]
          },
          "action": {
            "type": "ACTION",
            "shape": [
              5
            ]
          }
        },
        "norm_map": {
          "VISUAL": "IDENTITY",
          "STATE": "MEAN_STD",
          "LANGUAGE": "IDENTITY",
          "REWARD": "IDENTITY"
        }
      },
      "state_file": "policy_preprocessor_step_2_normalizer_processor.safetensors"
    },
    {
      "class": "lerobot_policy_sarm.processor_sarm.SARMEncodingProcessorStep",
      "config": {}
    },
    {
      "registry_name": "device_processor",
      "config": {
        "device": "cuda",
        "float_dtype": null
      }
    }
  ]
}